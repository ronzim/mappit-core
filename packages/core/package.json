{
    "name": "mappit-core",
    "version": "0.1.0",
    "description": "Core library for loading and processing Google Location History data",
    "license": "MIT",
    "author": "ronzim",
    "repository": {
        "type": "git",
        "url": "https://github.com/ronzim/mappit-core.git",
        "directory": "packages/core"
    },
    "keywords": [
        "google-location-history",
        "google-takeout",
        "location-history",
        "google-maps-timeline",
        "google-timeline-viewer",
        "takeout",
        "timeline",
        "geolocation",
        "gps",
        "gps-data",
        "kml",
        "kml-export",
        "location-data",
        "google-takeout-parser",
        "location-history-viewer",
        "privacy"
    ],
    "engines": {
        "node": ">=18"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "bin": {
        "mappit-core": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "dev": "tsc --project tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "docs": "typedoc",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "ora": "^5.4.1",
        "stream-json": "^1.7.4",
        "yargs": "^17.7.2"
    },
    "devDependencies": {
        "@types/node": "^22.13.4",
        "@types/stream-json": "^1.7.7",
        "@types/yargs": "^17.0.33",
        "typedoc": "^0.28.17",
        "vitest": "^3.0.6"
    }
}