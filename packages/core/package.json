{
    "name": "mappit-core",
    "version": "0.1.0",
    "description": "Core library for loading and processing Google Location History data",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "bin": {
        "mappit-core": "./dist/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "dev": "tsc --project tsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "ora": "^5.4.1",
        "stream-json": "^1.7.4",
        "yargs": "^17.7.2"
    },
    "devDependencies": {
        "@types/node": "^22.13.4",
        "@types/stream-json": "^1.7.7",
        "@types/yargs": "^17.0.33",
        "vitest": "^3.0.6"
    }
}
